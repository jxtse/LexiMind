.container {
  min-height: 100vh;
  background: #f4f6f6;
  position: relative;
}

.top-card {
  background: linear-gradient(180deg, #178e96 0%, #20a6ad 58%, rgba(244, 246, 246, 0) 100%);
  padding: 44rpx 30rpx 196rpx;
  position: relative;
  z-index: 1;
}

.brand {
  text-align: center;
  margin-bottom: 34rpx;
  color: #fde3c8;
  animation: floatIn 360ms ease-out both;
}

.brand-name {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.08;
}

.brand-slogan {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  opacity: 0.92;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 0 8rpx;
  margin: 0 auto;
  max-width: 690rpx;
  transition: transform 260ms ease;
  animation: liftIn 420ms ease-out 80ms both;
}

.search-box.is-focused {
  transform: translateY(-6rpx);
}

.search-bar {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 16rpx;
  padding: 16rpx 22rpx;
  box-shadow: 0 14rpx 34rpx rgba(20, 119, 128, 0.18);
  transition: box-shadow 220ms ease, border-color 220ms ease, background 220ms ease;
}

.search-box.is-focused .search-bar {
  background: #ffffff;
  border-color: rgba(253, 227, 200, 0.9);
  box-shadow: 0 18rpx 42rpx rgba(20, 119, 128, 0.24);
}

.search-input {
  flex: 1;
  height: 42rpx;
  line-height: 42rpx;
  font-size: 27rpx;
  color: #223033;
}

.placeholder {
  color: rgba(23, 142, 150, 0.58);
}

.clear-icon {
  flex: none;
  width: 40rpx;
  height: 40rpx;
  margin-left: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #178e96;
  font-size: 30rpx;
  opacity: 0.75;
  transition: opacity 160ms ease, transform 160ms ease;
}

.clear-icon:active {
  opacity: 0.45;
  transform: scale(0.88);
}

.search-btn {
  flex: none;
  width: 122rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  margin: 0;
  border-radius: 16rpx;
  background: #ffffff;
  color: #178e96;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 14rpx 30rpx rgba(20, 119, 128, 0.16);
  transition: transform 160ms ease, opacity 160ms ease;
}

.search-btn:active {
  opacity: 0.92;
  transform: translateY(3rpx) scale(0.98);
}

.search-btn[disabled] {
  color: rgba(23, 142, 150, 0.46);
  background: rgba(255, 255, 255, 0.68);
}

.content {
  padding: 0 24rpx 48rpx;
  margin-top: -132rpx;
  position: relative;
  z-index: 2;
}

.difficulty-card,
.topic-card {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 16rpx 44rpx rgba(33, 48, 51, 0.11);
  animation: cardIn 320ms ease-out both;
}

.difficulty-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #213033;
  margin-bottom: 10rpx;
}

.difficulty-hint {
  display: block;
  color: #697779;
  font-size: 24rpx;
  line-height: 1.45;
}

.difficulty-value {
  flex: none;
  min-width: 104rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #edf7f8;
  display: flex;
  align-items: baseline;
  justify-content: center;
  color: #178e96;
}

.difficulty-number {
  font-size: 46rpx;
  font-weight: 760;
  line-height: 80rpx;
}

.difficulty-total {
  font-size: 22rpx;
  margin-left: 2rpx;
}

.difficulty-slider {
  margin: 30rpx 0 10rpx;
}

.slider-scale {
  display: flex;
  justify-content: space-between;
  color: #879195;
  font-size: 22rpx;
}

.result-section {
  animation: cardIn 320ms ease-out both;
}

.topic-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 10rpx;
}

.topic-name {
  min-width: 0;
  color: #178e96;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.2;
}

.level-pill {
  flex: none;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #edf7f8;
  color: #178e96;
  font-size: 22rpx;
  font-weight: 600;
}

.topic-desc {
  display: block;
  color: #5d696c;
  font-size: 27rpx;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.generation-info {
  display: inline-flex;
  color: #7a8689;
  font-size: 24rpx;
}

.words-list {
  margin-bottom: 36rpx;
}

.word-card {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 16rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 12rpx 34rpx rgba(33, 48, 51, 0.09);
  overflow: hidden;
  animation: cardIn 300ms ease-out both;
  transition: transform 160ms ease;
}

.word-card:active {
  transform: translateY(3rpx);
}

.word-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  padding: 26rpx 26rpx 14rpx;
}

.word-main {
  min-width: 0;
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  flex-wrap: wrap;
}

.word {
  color: #213033;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.2;
}

.phonetic {
  color: #697779;
  font-size: 25rpx;
}

.difficulty-badge {
  flex: none;
  padding: 8rpx 14rpx;
  border-radius: 14rpx;
  color: #178e96;
  background: #edf7f8;
  font-size: 22rpx;
  font-weight: 600;
}

.word-body {
  padding: 0 26rpx 24rpx;
}

.translation {
  color: #178e96;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.definition {
  color: #5d696c;
  font-size: 27rpx;
  line-height: 1.5;
  margin-bottom: 14rpx;
}

.example-item {
  color: #808b8e;
  font-size: 25rpx;
  line-height: 1.55;
  padding-left: 16rpx;
  border-left: 4rpx solid #e1eeee;
}

.card-footer {
  padding: 18rpx 26rpx;
  background: #f8fbfb;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
}

.word-meta {
  color: #99a3a6;
}

.add-btn-small {
  color: #178e96;
  padding: 8rpx 20rpx;
  border-radius: 14rpx;
  background: rgba(23, 142, 150, 0.1);
  transition: transform 160ms ease, opacity 160ms ease;
}

.add-btn-small:active {
  opacity: 0.82;
  transform: scale(0.96);
}

.action-buttons {
  display: flex;
  gap: 18rpx;
  justify-content: center;
  padding: 18rpx 0 6rpx;
}

.action-btn {
  flex: 1;
  height: 82rpx;
  line-height: 82rpx;
  padding: 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  transition: transform 160ms ease, opacity 160ms ease;
}

.action-btn.primary {
  background: #178e96;
  color: white;
}

.action-btn.secondary {
  background: white;
  color: #178e96;
  border: 2rpx solid #178e96;
}

.action-btn:active {
  opacity: 0.9;
  transform: translateY(3rpx);
}

.empty-state {
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 34rpx 30rpx 56rpx;
  color: #178e96;
  text-align: center;
  animation: cardIn 360ms ease-out 80ms both;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 650;
  margin-bottom: 14rpx;
}

.empty-text {
  max-width: 540rpx;
  color: #687679;
  font-size: 26rpx;
  line-height: 1.55;
}

@keyframes floatIn {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes liftIn {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes cardIn {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
