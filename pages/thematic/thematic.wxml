<view
  class="container"
  bindtouchstart="onTouchStart"
  bindtouchmove="onTouchMove"
  bindtouchend="onTouchEnd"
  bindtouchcancel="onTouchEnd"
>
  <view class="top-card">
    <view class="brand">
      <text class="brand-name">主题词汇</text>
      <text class="brand-slogan">按场景生成真正用得上的英语词汇</text>
    </view>

    <view class="search-box {{searchFocused ? 'is-focused' : ''}}">
      <view class="search-bar">
        <input
          class="search-input"
          placeholder="例如：大都会博物馆、咖啡店、医院就诊"
          placeholder-class="placeholder"
          value="{{inputTopic}}"
          focus="{{searchFocused}}"
          bindinput="onTopicInput"
          bindfocus="onSearchFocus"
          bindblur="onSearchBlur"
          bindkeyboardheightchange="onKeyboardHeightChange"
          confirm-type="search"
          bindconfirm="generateWords"
        />
        <view class="clear-icon" bindtap="clearInput" wx:if="{{inputTopic}}">×</view>
      </view>
      <button class="search-btn" bindtap="generateWords" disabled="{{loading}}">
        {{loading ? '生成中' : '生成'}}
      </button>
    </view>
  </view>

  <view class="content">
    <view class="difficulty-card">
      <view class="difficulty-header">
        <view>
          <text class="card-title">生成难度</text>
          <text class="difficulty-hint">{{difficultyHint}}</text>
        </view>
        <view class="difficulty-value">
          <text class="difficulty-number">{{difficultyLevel}}</text>
          <text class="difficulty-total">/10</text>
        </view>
      </view>

      <slider
        class="difficulty-slider"
        min="1"
        max="10"
        step="1"
        value="{{difficultyLevel}}"
        activeColor="#178E96"
        backgroundColor="#d9eef0"
        block-color="#ffffff"
        block-size="24"
        bindchanging="onDifficultyChanging"
        bindchange="onDifficultyChange"
      />

      <view class="slider-scale">
        <text>日常</text>
        <text>进阶</text>
        <text>专业</text>
      </view>
    </view>

    <view class="result-section" wx:if="{{result}}">
      <view class="topic-card">
        <view class="topic-title-row">
          <text class="topic-name">{{result.topic}}</text>
          <text class="level-pill">难度 {{result.targetDifficultyLevel || difficultyLevel}}</text>
        </view>
        <text class="topic-desc">{{result.description}}</text>
        <text class="generation-info">已生成 {{result.words.length}} 个词汇</text>
      </view>

      <view class="words-list">
        <view
          class="word-card"
          wx:for="{{filteredWords}}"
          wx:key="word"
        >
          <view class="word-header">
            <view class="word-main">
              <text class="word">{{item.word}}</text>
              <text class="phonetic">[{{item.phonetic}}]</text>
            </view>
            <text class="difficulty-badge">Lv.{{item.difficultyLevel || result.targetDifficultyLevel || difficultyLevel}}</text>
          </view>

          <view class="word-body">
            <view class="translation">{{item.translation}}</view>
            <view class="definition">{{item.definition}}</view>
            <view class="example-item">{{item.example}}</view>
          </view>

          <view class="card-footer">
            <view class="word-meta">主题词汇</view>
            <view class="add-btn-small" bindtap="addToWordbook" data-word="{{item}}">
              加入生词本
            </view>
          </view>
        </view>
      </view>

      <view class="action-buttons">
        <button class="action-btn secondary" bindtap="clearResult">重新生成</button>
        <button class="action-btn primary" bindtap="addAllToWordbook">全部加入</button>
      </view>
    </view>

    <view class="empty-state" wx:if="{{!result}}">
      <text class="empty-title">下滑或点击输入框进行搜索</text>
      <text class="empty-text">调好难度后输入场景，LexiMind 会生成适合当前水平的词汇清单</text>
    </view>
  </view>
</view>
